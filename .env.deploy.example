# 复制为 .env.deploy（勿提交仓库），在本地项目根目录填写后执行: npm run deploy:vps
#
# SSH 登录目标（与你在终端里 ssh 的写法一致）
VIBY_DEPLOY_SSH=ubuntu@YOUR_SERVER_IP

# 服务器上 Viby 项目根目录（含 server.js、index.html）
VIBY_DEPLOY_PATH=/var/www/viby

# 可选：传给 ssh/rsync 的额外参数（密钥、端口等）
# VIBY_DEPLOY_SSH_CMD=ssh -i ~/.ssh/id_ed25519 -p 22

# 可选：PM2 应用名
# VIBY_DEPLOY_PM2_NAME=viby

# 可选：把本地某个生产环境文件同步到服务器 .env（路径相对仓库根目录）
# VIBY_DEPLOY_ENV_FILE=.env.production

# 可选：部署完成后用公网 URL 自检（script.js / share.js 是否已更新）
# VIBY_PUBLIC_URL=https://viby.ink
#
# 配好后可在本机执行：npm run publish（推 GitHub + 部署 VPS）
