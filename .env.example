PORT=4184
PUBLIC_ORIGIN=https://your-viby-domain.com
COOKIE_DOMAIN=.your-viby-domain.com
SESSION_SECRET=replace-with-a-long-random-secret

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email login
RESEND_API_KEY=
EMAIL_FROM=noreply@your-viby-domain.com

# Free / low-cost threat intel integrations
# Google Safe Browsing is free for non-commercial use according to Google's docs.
GOOGLE_SAFE_BROWSING_API_KEY=

# Optional; without an app key, PhishTank is still available but more rate-limited.
PHISHTANK_APP_KEY=
PHISHTANK_ALLOW_NO_KEY=0

# Toggle community feeds if needed.
OPENPHISH_DISABLED=0
PHISHTANK_DISABLED=0

# Admin moderation
ADMIN_EMAILS=admin@example.com
