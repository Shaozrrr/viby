GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# Node 监听（线上建议在 Nginx 后面只绑本机）
PORT=4184
HOST=0.0.0.0

# 与浏览器里访问的地址完全一致；生产示例：
# PUBLIC_ORIGIN=https://viby.ink
# HOST=127.0.0.1
#
# 若用户可能从 www.viby.ink 进入、而 GitHub 回调在 viby.ink，须让 Cookie 在子域间共享，否则 OAuth state 永远对不上：
# COOKIE_DOMAIN=.viby.ink
# 当 PUBLIC_ORIGIN 为「双段裸域」且未设置 COOKIE_DOMAIN 时，服务端会自动使用 `.裸域`（等价于上一行）。
#
# 若 Host 与 PUBLIC_ORIGIN 主机不一致（如访问 www 而 OAuth 回调在裸域），GET/HEAD 会 301 到 PUBLIC_ORIGIN。
# 多域名特殊部署时关闭：VIBY_DISABLE_CANONICAL_HOST_REDIRECT=1

# 会话 Cookie 签名（推荐单独配置，勿泄露到前端）
# SESSION_SECRET=长随机字符串

# 若 PM2 / 系统环境里的 GITHUB_CLIENT_SECRET 与 .env 不一致会导致「登录后仍 401」，
# 取消下行注释，强制以 .env 中的密钥作为会话签名与 OAuth token 交换（须与 GitHub App 一致）。
# VIBY_DOTENV_OVERRIDE=1

# 本地开发示例（与 GitHub OAuth 回调一致，localhost / 127.0.0.1 勿混用）
# PUBLIC_ORIGIN=http://127.0.0.1:4184
